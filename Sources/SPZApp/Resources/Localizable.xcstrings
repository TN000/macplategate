        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Password changed. Initial-password file (if any) has been deleted."
          }
        }
      }
    },
    "Uložení hesla selhalo: \\(error.localizedDescription)": {
      "extractionState": "manual",
