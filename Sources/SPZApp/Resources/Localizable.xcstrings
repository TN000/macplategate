          }
        }
      }
    },
    "TATO SEKCE NASTAVUJE JAK APLIKACE ROZHODUJE KDY SI JE JISTÁ, ŽE PŘEČETLA SPZ SPRÁVNĚ. ŠPATNÉ HODNOTY VEDOU BUĎ K CHYBNÝM ZÁZNAMŮM (PŘEČTE TEXT, KTERÝ NENÍ SPZ), NEBO NAOPAK K TOMU, ŽE APLIKACE NEZAZNAMENÁ VŮBEC NIC. POKUD NEVÍŠ CO DĚLÁŠ, NECH DEFAULTY.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "THIS SECTION CONFIGURES HOW THE APP DECIDES WHEN IT'S CONFIDENT IT HAS READ THE PLATE CORRECTLY. WRONG VALUES CAUSE EITHER FALSE RECORDS (READS TEXT THAT ISN'T A PLATE) OR THE APP MISSING DETECTIONS ENTIRELY. IF YOU DON'T KNOW WHAT YOU'RE DOING, LEAVE THE DEFAULTS."
          }
        }
      }
    },
    "VRÁTÍ VŠECHNY HODNOTY NA PŮVODNÍ ROZUMNÉ VÝCHOZÍ HODNOTY.": {
