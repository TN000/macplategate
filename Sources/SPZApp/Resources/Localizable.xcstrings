    "POUZE PRO ZNÁMÉ SPZ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ONLY FOR KNOWN PLATES"
          }
        }
      }
    },
    "KDYŽ ZAPNUTO, OTEVŘE ZÁVORU POUZE AUTŮM ZE SEZNAMU ZNÁMÝCH SPZ. KDYŽ VYPNUTO, OTEVŘE KAŽDÉMU AUTU (VČETNĚ NEZNÁMÝCH) — NEDOPORUČENO PRO OSTRÝ PROVOZ.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WHEN ENABLED, OPENS THE GATE ONLY FOR CARS ON THE KNOWN PLATES LIST. WHEN DISABLED, OPENS FOR EVERY CAR (INCLUDING UNKNOWN) — NOT RECOMMENDED FOR PRODUCTION."
          }
        }
      }
    },
    "POČET OPAKOVANÝCH POKUSŮ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RETRY COUNT"
          }
        }
      }
    },
    "POKUD SE NEPODAŘÍ ODESLAT PŘÍKAZ NA ZÁVORU NAPOPRVÉ (NAPŘ. RELÉ ZROVNA NEODPOVÍDÁ), KOLIKRÁT TO ZKUSIT ZNOVU. 0 = ZKUSÍ JEN JEDNOU.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "IF THE GATE COMMAND FAILS ON THE FIRST ATTEMPT (E.G. THE RELAY DOESN'T RESPOND), HOW MANY TIMES TO RETRY. 0 = SINGLE ATTEMPT."
          }
        }
      }
    },
    "BEZ OPAKOVÁNÍ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NO RETRIES"
          }
        }
      }
    },
    "ČASOVÝ LIMIT NA ODPOVĚĎ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RESPONSE TIMEOUT"
          }
        }
      }
    },
    "JAK DLOUHO ČEKAT NA ODPOVĚĎ OD RELÉ, NEŽ POKUS POVAŽOVAT ZA NEÚSPĚŠNÝ. 2000 MS = 2 SEKUNDY. POKUD MÁŠ POMALOU SÍŤ, ZVYŠ.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HOW LONG TO WAIT FOR A REPLY FROM THE RELAY BEFORE CONSIDERING THE ATTEMPT FAILED. 2000 MS = 2 SECONDS. IF YOUR NETWORK IS SLOW, RAISE IT."
          }
        }
      }
    },
    "ODESÍLÁM…": {
