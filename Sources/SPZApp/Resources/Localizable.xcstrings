          "stringUnit": {
            "state": "translated",
            "value": "FIND A REFERENCE PLATE. DRAG THE 4 BLUE POINTS TO ITS CORNERS (TL/TR/BR/BL). (WHEEL = ZOOM · DRAG OUTSIDE HANDLES = PAN)"
          }
        }
      }
    },
