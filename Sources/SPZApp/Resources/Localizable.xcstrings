    "RATE LIMITED (ČEKEJ 2 S)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RATE LIMITED (WAIT 2 S)"
          }
        }
      }
    },
    "KDYŽ VYPNUTO, SPZ TOMUTO SHELLY ZAŘÍZENÍ NEPOSÍLÁ ŽÁDNÉ PŘÍKAZY. ALPR AUTO-FIRE NA TÉTO KAMEŘE A WEBOVÉ UI TLAČÍTKA JSOU IGNOROVÁNY.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WHEN DISABLED, THE APP SENDS NO COMMANDS TO THIS SHELLY DEVICE. ALPR AUTO-FIRE ON THIS CAMERA AND WEB UI BUTTONS ARE IGNORED."
          }
        }
      }
    },
    "KRÁTKÝ PULSE (OTEVŘI)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SHORT PULSE (OPEN)"
          }
        }
      }
    },
    "DÉLKA PULSU PRO STANDARDNÍ PRŮJEZD. SHELLY TOGGLE_AFTER PARAMETER, AGN2/AGN3 ŘADIČ SI PAK ZAVŘE SÁM.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PULSE LENGTH FOR A STANDARD PASS. SHELLY TOGGLE_AFTER PARAMETER; THE AGN2/AGN3 CONTROLLER THEN CLOSES ITSELF."
          }
        }
      }
    },
    "DLOUHÝ PULSE (AUTOBUS)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LONG PULSE (BUS)"
          }
        }
      }
    },
    "PULSE PRO VELKÁ VOZIDLA — DRŽÍ RELÉ SEPNUTÉ PO CELOU DOBU. DOPORUČENO 15–30 S.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PULSE FOR LARGE VEHICLES — HOLDS THE RELAY CLOSED FOR THE FULL DURATION. RECOMMENDED 15–30 S."
          }
        }
      }
    },
    "V HOLD-OPEN REŽIMU SPZ POSÍLÁ `TOGGLE_AFTER=N` KAŽDOU 1 S. N MUSÍ BÝT ≥ 3 (3× REDUNDANCE PER CYCLE).": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "IN HOLD-OPEN MODE THE APP SENDS `TOGGLE_AFTER=N` EVERY 1 S. N MUST BE ≥ 3 (3× REDUNDANCY PER CYCLE)."
          }
        }
      }
    },
    "RATE LIMITED (POČKEJ 2 S)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RATE LIMITED (WAIT 2 S)"
          }
        }
      }
    },
    "SOUČASNÉ HESLO NENÍ SPRÁVNÉ.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CURRENT PASSWORD IS INCORRECT."
          }
        }
      }
    },
