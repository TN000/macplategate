    "Shelly Pro 1 (gen 2 firmware) používá Digest auth. URLSession kredence injektne přes URL userinfo a odpoví na 401 challenge automaticky.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shelly Pro 1 (gen 2 firmware) uses Digest auth. URLSession injects credentials via URL userinfo and responds to the 401 challenge automatically."
          }
        }
      }
    },
    "Test krátké": {
      "extractionState": "manual",
      "localizations": {
