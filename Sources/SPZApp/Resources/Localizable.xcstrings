      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "leave blank = no auth"
          }
        }
      }
    },
    "Heslo chrání přístup k Nastavení, whitelist editoru a dalším admin akcím. Hash je uložený lokálně v chráněném souboru s právy 0600.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The password protects access to Settings, the whitelist editor, and other admin actions. The hash is stored locally in a protected file with 0600 permissions."
          }
        }
      }
    },
