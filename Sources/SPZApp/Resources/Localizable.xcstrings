    "UPOZORNĚNÍ PRO DLOUHO NEVIDĚNÉ SPZ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ALERTS FOR LONG-UNSEEN PLATES"
          }
        }
      }
    },
    "DENNĚ PROJDE WHITELIST A HLÁSÍ SPZ CO NEBYLA DETEKOVÁNA DÉLE NEŽ ZVOLENÝ POČET DNÍ. VHODNÉ PRO FIREMNÍ PROVOZ — UPOZORNÍ, ŽE ZAMĚSTNANEC / ZÁKAZNÍK PŘESTAL JEZDIT. LOG: [UNSEENALERTER] FIRE PLATE=X LASTSEEN=... V SPZ.LOG. DEDUP 7 DNÍ PER SPZ (NESPAMUJE).": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DAILY WALKS THE WHITELIST AND REPORTS PLATES NOT DETECTED FOR MORE THAN THE CHOSEN NUMBER OF DAYS. USEFUL IN COMPANY OPERATION — ALERTS THAT AN EMPLOYEE/CUSTOMER STOPPED COMING. LOG: [UNSEENALERTER] FIRE PLATE=X LASTSEEN=… IN SPZ.LOG. DEDUP 7 DAYS PER PLATE (NO SPAM)."
          }
        }
      }
    },
    "PRÁH NEAKTIVITY (DNY)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "INACTIVITY THRESHOLD (DAYS)"
          }
        }
      }
    },
    "KOLIK DNÍ MUSÍ SPZ NEBÝT VIDĚNA ABY SE VYSTŘELILO UPOZORNĚNÍ. DEFAULT 30 DNÍ = MĚSÍČNÍ OKNO.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HOW MANY DAYS A PLATE MUST BE UNSEEN BEFORE AN ALERT FIRES. DEFAULT 30 DAYS = MONTHLY WINDOW."
          }
        }
      }
    },
    "UCHOVAT POČET DNÍ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RETENTION DAYS"
          }
        }
      }
    },
    "JAK DLOUHO SE UKLÁDAJÍ FOTKY ZAZNAMENANÝCH SPZ. PO TÉTO DOBĚ SE STARŠÍ FOTKY AUTOMATICKY MAŽOU, ABY NEZABÍRALY MÍSTO. 0 = UCHOVÁVAT NAVŽDY (POZOR — DISK SE BUDE PLNIT).": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HOW LONG CAPTURED PLATE PHOTOS ARE KEPT. AFTER THIS TIME OLDER PHOTOS ARE AUTOMATICALLY DELETED TO SAVE SPACE. 0 = KEEP FOREVER (WARNING — DISK WILL FILL UP)."
          }
        }
      }
    },
    "MAXIMÁLNĚ SOUBORŮ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MAX FILE COUNT"
          }
        }
      }
    },
    "HORNÍ STROP POČTU ULOŽENÝCH FOTEK. PŘI PŘEKROČENÍ SE SMAŽOU NEJSTARŠÍ. 0 = BEZ LIMITU.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "UPPER CAP ON STORED PHOTO COUNT. WHEN EXCEEDED, OLDEST ARE DELETED. 0 = NO LIMIT."
          }
        }
      }
    },
    "1024–65535, DEFAULT 22224. PO ZMĚNĚ SE SERVER RESTARTUJE.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1024–65535, DEFAULT 22224. THE SERVER RESTARTS AFTER A CHANGE."
          }
        }
      }
    },
    "PRAVIDLA: MIN. 12 ZNAKŮ; ALESPOŇ 3 TYPY ZNAKŮ (VELKÁ PÍSMENA, MALÁ, ČÍSLICE, SPECIÁLNÍ); ŽÁDNÝ ZNÁMÝ VZOR JAKO \\\"ADMIN\\\", \\\"HESLO\\\", \\\"12345\\\", \\\"KAMERASZM\\\".": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RULES: MIN. 12 CHARS; AT LEAST 3 CHARACTER TYPES (UPPERCASE, LOWERCASE, DIGITS, SYMBOLS); NO COMMON PATTERNS LIKE \\\"ADMIN\\\", \\\"PASSWORD\\\", \\\"12345\\\"."
          }
        }
      }
    },
    "PO 5 NEÚSPĚŠNÝCH POKUSECH O PŘIHLÁŠENÍ Z JEDNÉ IP SE TA IP ZABLOKUJE NA 5 MINUT. CHRÁNÍ PROTI HÁDÁNÍ HESLA. DOPORUČENO NECHAT ZAPNUTÉ.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AFTER 5 FAILED LOGIN ATTEMPTS FROM ONE IP, THAT IP IS BLOCKED FOR 5 MINUTES. PROTECTS AGAINST PASSWORD GUESSING. RECOMMENDED TO LEAVE ON."
          }
        }
      }
    },
